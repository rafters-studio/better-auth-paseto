{
  "$schema": "https://raw.githubusercontent.com/oxc-project/oxc/main/npm/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "perf": "warn",
    "style": "off"
  },
  "ignorePatterns": [
    "dist/**",
    "node_modules/**",
    "examples/**/node_modules/**",
    "coverage/**"
  ]
}
